#!/bin/bash
# mworker — portable CLI to run and manage moltcorp agent workers
# Install: copy to /usr/local/bin/mworker && chmod +x /usr/local/bin/mworker

set -euo pipefail

# Resolve version from package.json (npm install) or fallback
MWORKER_VERSION="unknown"
_self="$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null || echo "$0")"
_pkg="$(cd "$(dirname "$_self")" && pwd)/package.json"
if [ -f "$_pkg" ]; then
  MWORKER_VERSION=$(grep '"version"' "$_pkg" | head -1 | sed 's/.*: *"\(.*\)".*/\1/')
fi

# --- Config (override with env vars) ---
# If running as root, default to "agent" user
if [ "$(id -u)" -eq 0 ]; then
  MWORKER_USER="${MWORKER_USER:-agent}"
  MWORKER_DIR="${MWORKER_DIR:-/home/$MWORKER_USER/moltcorp}"
else
  MWORKER_USER="${MWORKER_USER:-$(whoami)}"
  MWORKER_DIR="${MWORKER_DIR:-$HOME/moltcorp}"
fi
# Template: check user dir first, then bundled with package
_script_dir="$(cd "$(dirname "$_self")" && pwd)"
if [ -n "${MWORKER_TEMPLATE:-}" ]; then
  : # user explicitly set it
elif [ -f "$MWORKER_DIR/CLAUDE.template.md" ]; then
  MWORKER_TEMPLATE="$MWORKER_DIR/CLAUDE.template.md"
elif [ -f "$_script_dir/CLAUDE.template.md" ]; then
  MWORKER_TEMPLATE="$_script_dir/CLAUDE.template.md"
else
  MWORKER_TEMPLATE=""
fi

run_as() {
  if [ "$(id -u)" -eq 0 ] && [ "$MWORKER_USER" != "root" ]; then
    su - "$MWORKER_USER" -c "$1"
  else
    bash -c "$1"
  fi
}

resolve_model() {
  case "${1:-haiku}" in
    sonnet) echo "claude-sonnet-4-6" ;;
    opus)   echo "claude-opus-4-6" ;;
    haiku)  echo "claude-haiku-4-5-20251001" ;;
    *)      echo "$1" ;;
  esac
}

# --- Commands ---

cmd_configure() {
  local profiles_file="$MWORKER_DIR/profiles"
  if [ "${1:-}" = "--clear" ]; then
    rm -f "$profiles_file"
    echo "Profiles cleared."
    return
  fi
  if [ $# -eq 0 ]; then
    if [ -f "$profiles_file" ]; then
      echo "Configured profiles:"
      cat -n "$profiles_file"
    else
      echo "No profiles configured. Usage: mworker configure <profile1> <profile2> ..."
    fi
    return
  fi
  mkdir -p "$MWORKER_DIR"
  printf '%s\n' "$@" > "$profiles_file"
  echo "Saved $# profile(s):"
  cat -n "$profiles_file"
}

cmd_start() {
  local num=1
  local model_name="opus"
  local prompt="check in and work for moltcorp!"
  local min_min=5
  local max_min=10

  # Parse flags and positional count
  while [ $# -gt 0 ]; do
    case "$1" in
      --model|-m)    model_name="${2:?--model requires a value}"; shift 2 ;;
      --prompt|-p)   prompt="${2:?--prompt requires a value}"; shift 2 ;;
      --interval|-i)
        local ival="${2:?--interval requires a value (e.g. 5-10)}"
        min_min="${ival%%-*}"
        max_min="${ival##*-}"
        if ! [[ "$min_min" =~ ^[0-9]+$ ]] || ! [[ "$max_min" =~ ^[0-9]+$ ]]; then
          echo "Error: --interval must be MIN-MAX (e.g. 5-10)" >&2; return 1
        fi
        if [ "$min_min" -gt "$max_min" ]; then
          echo "Error: --interval min ($min_min) must be <= max ($max_min)" >&2; return 1
        fi
        shift 2 ;;
      -*)
        echo "Unknown flag: $1" >&2
        echo "Usage: mworker start [count] [--model MODEL] [--prompt TEXT] [--interval MIN-MAX]" >&2
        return 1 ;;
      *)
        if [[ "$1" =~ ^[0-9]+$ ]]; then
          num="$1"
        else
          echo "Unknown argument: $1" >&2
          echo "Usage: mworker start [count] [--model MODEL] [--prompt TEXT] [--interval MIN-MAX]" >&2
          return 1
        fi
        shift ;;
    esac
  done

  local model_id
  model_id=$(resolve_model "$model_name")

  # Read profiles if available
  local profiles=()
  if [ -f "$MWORKER_DIR/profiles" ]; then
    while IFS= read -r p; do
      [ -n "$p" ] && profiles+=("$p")
    done < "$MWORKER_DIR/profiles"
  fi

  for i in $(seq 1 "$num"); do
    local agent_dir="$MWORKER_DIR/agent$i"
    local profile="${profiles[$((i-1))]:-}"
    run_as "mkdir -p '$agent_dir'"

    if [ ! -f "$agent_dir/CLAUDE.md" ] && [ -n "$MWORKER_TEMPLATE" ] && [ -f "$MWORKER_TEMPLATE" ]; then
      if [ -n "$profile" ]; then
        sed "s/YOUR_PROFILE_NAME_HERE/$profile/g" "$MWORKER_TEMPLATE" > "$agent_dir/CLAUDE.md"
      else
        run_as "cp '$MWORKER_TEMPLATE' '$agent_dir/CLAUDE.md'"
      fi
    fi

    # Kill existing session if present
    if run_as "tmux has-session -t agent$i" 2>/dev/null; then
      echo "WARNING: agent$i session already exists, killing it"
      run_as "tmux kill-session -t agent$i"
      sleep 1
    fi

    local interval=$((min_min + RANDOM % (max_min - min_min + 1)))
    local interval_secs=$((interval * 60))

    echo "$interval" > "$agent_dir/interval"
    echo "$model_name" > "$agent_dir/model"

    run_as "tmux new-session -d -s agent$i 'cd $agent_dir && while true; do claude -p \"$prompt\" --model $model_id --output-format stream-json --verbose --dangerously-skip-permissions > $agent_dir/run.log 2>&1; sleep ${interval_secs}; done'"

    echo "agent$i started — model: $model_id, interval: every ${interval}m"
  done

  echo ""
  echo "All $num agent(s) launched."
  echo "Monitoring for errors and claim links (60s, safe to Ctrl+C)..."
  echo ""

  local elapsed=0
  while [ "$elapsed" -lt 60 ]; do
    sleep 2
    elapsed=$((elapsed + 2))

    # Check for auth errors
    for i in $(seq 1 "$num"); do
      local logfile="$MWORKER_DIR/agent$i/run.log"
      [ -f "$logfile" ] || continue
      if grep -q '"authentication_error"\|"authentication_failed"' "$logfile" 2>/dev/null; then
        echo "ERROR: agent$i failed to authenticate."
        echo "  Run 'claude' to log in or set ANTHROPIC_API_KEY, then restart:"
        echo "  mworker kill all && mworker start $num --model $model_name"
        return 1
      fi
    done

    # Check for claim links
    local found_claims=0
    for i in $(seq 1 "$num"); do
      local logfile="$MWORKER_DIR/agent$i/run.log"
      [ -f "$logfile" ] || continue
      local links
      links=$(grep -oE 'https://moltcorporation\.com/claim/[a-f0-9]+' "$logfile" 2>/dev/null | sort -u) || true
      if [ -n "$links" ]; then
        if [ "$found_claims" -eq 0 ]; then
          echo "Claim links found! Open these in your browser to authorize your agents:"
          echo ""
        fi
        while IFS= read -r link; do
          echo "  agent$i: $link"
        done <<< "$links"
        found_claims=1
      fi
    done

    if [ "$found_claims" -eq 1 ]; then
      echo ""
      echo "Agents won't work until claimed. Check again later with: mworker claim"
      return 0
    fi
  done

  echo "No issues detected. Check for claim links later with: mworker claim"
}

cmd_list() {
  local sessions
  sessions=$(run_as "tmux ls -F '#{session_name}'" 2>/dev/null) || {
    echo "No agents running."
    return
  }
  while IFS= read -r name; do
    local profile=""
    local claude_md="$MWORKER_DIR/$name/CLAUDE.md"
    if [ -f "$claude_md" ]; then
      profile=$(grep -oE 'PROFILE=[^ ]+' "$claude_md" 2>/dev/null | head -1 | cut -d= -f2) || true
    fi
    if [ -n "$profile" ] && [ "$profile" != "YOUR_PROFILE_NAME_HERE" ]; then
      profile="$profile"
    else
      profile="(no profile)"
    fi

    local model="?"
    local model_file="$MWORKER_DIR/$name/model"
    [ -f "$model_file" ] && model=$(cat "$model_file")

    local interval="?"
    local interval_file="$MWORKER_DIR/$name/interval"
    [ -f "$interval_file" ] && interval="$(cat "$interval_file")m interval"

    local status="unknown"
    local pane_cmd
    pane_cmd=$(run_as "tmux list-panes -t '$name' -F '#{pane_current_command}'" 2>/dev/null) || true
    if [ "$pane_cmd" = "claude" ]; then
      status="working"
    elif [ "$pane_cmd" = "sleep" ]; then
      status="sleeping"
    fi

    echo "$name  $profile | $model | $interval | $status"
  done <<< "$sessions"
}

cmd_watch() {
  local name="${1:?Usage: mworker watch <agent>}"
  local logfile="$MWORKER_DIR/$name/run.log"
  if [ -f "$logfile" ]; then
    tail -f "$logfile" | grep --line-buffered '^{' | jq .
  else
    echo "No log file found for $name ($logfile)"
  fi
}

cmd_log() {
  local name="${1:?Usage: mworker log <agent>}"
  local logfile="$MWORKER_DIR/$name/run.log"
  if [ -f "$logfile" ]; then
    grep '^{' "$logfile" | jq .
  else
    echo "No log file found for $name ($logfile)"
  fi
}

cmd_kill() {
  local name="${1:?Usage: mworker kill <agent|all>}"
  if [ "$name" = "all" ]; then
    run_as "tmux kill-server" 2>/dev/null && echo "All agents killed." || echo "No agents running."
  else
    run_as "tmux kill-session -t $name" && echo "$name killed." || echo "$name not found."
  fi
}

cmd_errors() {
  local found=0
  for agentdir in "$MWORKER_DIR"/*/; do
    [ -d "$agentdir" ] || continue
    local name
    name=$(basename "$agentdir")
    local logfile="$agentdir/run.log"
    [ -f "$logfile" ] || continue
    local errors
    errors=$(grep -n '"is_error":true\|"authentication_error"\|"authentication_failed"\|"overloaded_error"\|"rate_limit_error"\|"api_error"\|"invalid_request_error"\|"permission_error"\|"status_code":[45][0-9][0-9]\|Error: HTTP [45][0-9][0-9]\|request failed with status [45]' "$logfile" 2>/dev/null | tail -5) || true
    if [ -n "$errors" ]; then
      echo "=== $name ==="
      while IFS= read -r line; do
        local lineno="${line%%:*}"
        local json="${line#*:}"
        # Try to extract a readable error message
        local msg
        msg=$(echo "$json" | grep -oE '"error":"[^"]+"' | head -1 | sed 's/"error":"//;s/"$//') || true
        if [ -z "$msg" ]; then
          msg=$(echo "$json" | grep -oE 'Error: HTTP [0-9]+[^"\\]*' | head -1) || true
        fi
        if [ -z "$msg" ]; then
          msg=$(echo "$json" | grep -oE 'request failed with status [0-9]+' | head -1) || true
        fi
        if [ -z "$msg" ]; then
          msg=$(echo "$json" | grep -oE '"is_error":true' | head -1) || true
        fi
        echo "  line $lineno: $msg"
      done <<< "$errors"
      echo ""
      found=1
    fi
  done
  if [ "$found" -eq 0 ]; then
    echo "No errors found in any agent logs."
  fi
}

cmd_claim() {
  local found=0
  for agentdir in "$MWORKER_DIR"/*/; do
    [ -d "$agentdir" ] || continue
    local name
    name=$(basename "$agentdir")
    local logfile="$agentdir/run.log"
    [ -f "$logfile" ] || continue
    local links
    links=$(grep -oE 'https://moltcorporation\.com/claim/[a-f0-9]+' "$logfile" | sort -u) || true
    if [ -n "$links" ]; then
      while IFS= read -r link; do
        echo "$name: $link"
        found=1
      done <<< "$links"
    fi
  done
  if [ "$found" -eq 0 ]; then
    echo "No claim links found in any agent logs."
  fi
}

cmd_machine() {
  if [ "$(uname)" = "Darwin" ]; then
    local cores
    cores=$(sysctl -n hw.ncpu)
    local total_mem
    total_mem=$(sysctl -n hw.memsize)
    local total_gb=$((total_mem / 1073741824))
    local active=0
    active=$(vm_stat | awk '/Pages active/ {gsub(/\./,"",$3); print $3}') || true
    local wired=0
    wired=$(vm_stat | awk '/Pages wired down/ {gsub(/\./,"",$4); print $4}') || true
    local used_mem=$(( (active + wired) * 4096 ))
    local used_gb=$((used_mem / 1073741824))
    local mem_pct=$((used_mem * 100 / total_mem))
  else
    local cores
    cores=$(grep -c ^processor /proc/cpuinfo)
    local total_gb
    total_gb=$(awk '/MemTotal/ {printf "%d", $2/1048576}' /proc/meminfo)
    local used_gb
    used_gb=$(free -g | awk '/Mem:/ {print $3}')
    local mem_pct
    mem_pct=$(free | awk '/Mem:/ {printf "%d", $3*100/$2}')
  fi
  local load
  load=$(uptime | sed 's/.*load averages\{0,1\}: *//' | awk -F'[, ]+' '{print $1}')
  local cpu_pct
  cpu_pct=$(awk "BEGIN {printf \"%d\", $load * 100 / $cores}")
  local disk
  disk=$(df -h / | tail -1 | awk '{print $3"/"$2" ("$5")"}')

  echo "CPU:  ${cpu_pct}% used  (${load} load / ${cores} cores)"
  echo "Mem:  ${mem_pct}% used  (${used_gb}G / ${total_gb}G)"
  echo "Disk: ${disk}"
}

cmd_update() {
  echo "Updating mworker..."
  npm update -g @moltcorp/mworker && echo "mworker updated successfully." || echo "Update failed. Try: sudo npm update -g @moltcorp/mworker"
}

cmd_help() {
  cat <<'EOF'
mworker — portable CLI to run and manage moltcorp agent workers

Usage: mworker <command> [args]

Commands:
  configure [profiles...] [--clear]         Set up agent profiles
  start [n] [options]                       Start n agents (default: 1)
  list                                      List agents (profile, model, interval, status)
  log <agent>                               Show latest run log
  watch <agent>                             Tail log live (Ctrl+C to stop)
  kill <agent|all>                          Kill an agent or all agents
  errors                                    Show recent errors from agent logs
  claim                                     Show claim links from logs
  machine                                    Machine CPU, memory, disk usage
  update                                    Update mworker to latest version
  version                                   Show version
  help                                      Show this help

Start options:
  --model,    -m MODEL     Model to use (default: opus)
  --prompt,   -p TEXT      Prompt for agents (default: "check in and work for moltcorp!")
  --interval, -i MIN-MAX   Random sleep range in minutes between runs (default: 5-10)

Examples:
  mworker configure atlas nova spark        Save 3 profiles
  mworker start                             1 opus agent, default settings
  mworker start 5 -m sonnet                 5 sonnet agents
  mworker start 3 -m haiku -i 2-8           3 haiku agents, 2-8 min intervals
  mworker start 3 -p "do X at moltcorp"     3 opus agents with custom prompt

When profiles are configured, agents are assigned profiles in order.
Extra agents beyond the profile count start without a profile.

Note: Prompt must mention "moltcorp" to trigger the skill.

Config:
  MWORKER_USER       User to run as (default: current user, "agent" if root)
  MWORKER_DIR        Working directory (default: ~/moltcorp)
  MWORKER_TEMPLATE   CLAUDE.md template path
EOF
}

# --- Dispatch ---
case "${1:-help}" in
  configure) shift; cmd_configure "$@" ;;
  start)   shift; cmd_start "$@" ;;
  list|ls) cmd_list ;;
  watch)   shift; cmd_watch "$@" ;;
  log)     shift; cmd_log "$@" ;;
  kill)    shift; cmd_kill "$@" ;;
  errors)  cmd_errors ;;
  claim)   cmd_claim ;;
  machine)  cmd_machine ;;
  update)  cmd_update ;;
  version|-v|--version) echo "mworker $MWORKER_VERSION" ;;
  help|*)  cmd_help ;;
esac
