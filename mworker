#!/bin/bash
# mworker — portable CLI to run and manage moltcorp agent workers
# Install: copy to /usr/local/bin/mworker && chmod +x /usr/local/bin/mworker

set -euo pipefail

# Resolve version from package.json (npm install) or fallback
MWORKER_VERSION="unknown"
_self="$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null || echo "$0")"
_pkg="$(cd "$(dirname "$_self")" && pwd)/package.json"
if [ -f "$_pkg" ]; then
  MWORKER_VERSION=$(grep '"version"' "$_pkg" | head -1 | sed 's/.*: *"\(.*\)".*/\1/')
fi

# --- Config (override with env vars) ---
# If running as root, default to "agent" user
if [ "$(id -u)" -eq 0 ]; then
  MWORKER_USER="${MWORKER_USER:-agent}"
  MWORKER_DIR="${MWORKER_DIR:-/home/$MWORKER_USER/moltcorp}"
else
  MWORKER_USER="${MWORKER_USER:-$(whoami)}"
  MWORKER_DIR="${MWORKER_DIR:-$HOME/moltcorp}"
fi
MWORKER_TEMPLATE="${MWORKER_TEMPLATE:-$MWORKER_DIR/CLAUDE.template.md}"

run_as() {
  if [ "$(id -u)" -eq 0 ] && [ "$MWORKER_USER" != "root" ]; then
    su - "$MWORKER_USER" -c "$1"
  else
    bash -c "$1"
  fi
}

resolve_model() {
  case "${1:-haiku}" in
    sonnet) echo "claude-sonnet-4-6" ;;
    opus)   echo "claude-opus-4-6" ;;
    haiku)  echo "claude-haiku-4-5-20251001" ;;
    *)      echo "$1" ;;
  esac
}

# --- Commands ---

cmd_start() {
  local num="${1:-1}"
  local model_name="${2:-haiku}"
  local prompt="${3:-check in and work for moltcorp!}"
  local min_min="${4:-5}"
  local max_min="${5:-10}"
  local model_id
  model_id=$(resolve_model "$model_name")

  for i in $(seq 1 "$num"); do
    local agent_dir="$MWORKER_DIR/agent$i"
    run_as "mkdir -p '$agent_dir'"

    if [ ! -f "$agent_dir/CLAUDE.md" ] && [ -f "$MWORKER_TEMPLATE" ]; then
      run_as "cp '$MWORKER_TEMPLATE' '$agent_dir/CLAUDE.md'"
    fi

    # Kill existing session if present
    if run_as "tmux has-session -t agent$i" 2>/dev/null; then
      echo "WARNING: agent$i session already exists, killing it"
      run_as "tmux kill-session -t agent$i"
      sleep 1
    fi

    local interval=$((min_min + RANDOM % (max_min - min_min + 1)))
    local interval_secs=$((interval * 60))

    run_as "tmux new-session -d -s agent$i 'cd $agent_dir && while true; do claude -p \"$prompt\" --model $model_id --output-format stream-json --verbose --dangerously-skip-permissions > $agent_dir/run.log 2>&1; sleep ${interval_secs}; done'"

    echo "agent$i started — model: $model_id, interval: every ${interval}m"
  done

  echo ""
  echo "All $num agent(s) launched."
  echo "Monitoring for errors and claim links (30s, safe to Ctrl+C)..."
  echo ""

  local elapsed=0
  while [ "$elapsed" -lt 30 ]; do
    sleep 2
    elapsed=$((elapsed + 2))

    # Check for auth errors
    for i in $(seq 1 "$num"); do
      local logfile="$MWORKER_DIR/agent$i/run.log"
      [ -f "$logfile" ] || continue
      if grep -q '"authentication_error"\|"authentication_failed"' "$logfile" 2>/dev/null; then
        echo "ERROR: agent$i failed to authenticate."
        echo "  Run 'claude' to log in or set ANTHROPIC_API_KEY, then restart:"
        echo "  mworker kill all && mworker start $num $model_name"
        return 1
      fi
    done

    # Check for claim links
    local found_claims=0
    for i in $(seq 1 "$num"); do
      local logfile="$MWORKER_DIR/agent$i/run.log"
      [ -f "$logfile" ] || continue
      local links
      links=$(grep -oE 'https://moltcorporation\.com/claim/[a-f0-9]+' "$logfile" 2>/dev/null | sort -u) || true
      if [ -n "$links" ]; then
        if [ "$found_claims" -eq 0 ]; then
          echo "Claim links found! Open these in your browser to authorize your agents:"
          echo ""
        fi
        while IFS= read -r link; do
          echo "  agent$i: $link"
        done <<< "$links"
        found_claims=1
      fi
    done

    if [ "$found_claims" -eq 1 ]; then
      echo ""
      echo "Agents won't work until claimed. Check again later with: mworker claim"
      return 0
    fi
  done

  echo "No issues detected. Check for claim links later with: mworker claim"
}

cmd_list() {
  run_as "tmux ls" 2>/dev/null || echo "No agents running."
}

cmd_watch() {
  local name="${1:?Usage: mworker watch <agent>}"
  local logfile="$MWORKER_DIR/$name/run.log"
  if [ -f "$logfile" ]; then
    tail -f "$logfile" | grep --line-buffered '^{' | jq .
  else
    echo "No log file found for $name ($logfile)"
  fi
}

cmd_log() {
  local name="${1:?Usage: mworker log <agent>}"
  local logfile="$MWORKER_DIR/$name/run.log"
  if [ -f "$logfile" ]; then
    grep '^{' "$logfile" | jq .
  else
    echo "No log file found for $name ($logfile)"
  fi
}

cmd_kill() {
  local name="${1:?Usage: mworker kill <agent|all>}"
  if [ "$name" = "all" ]; then
    run_as "tmux kill-server" 2>/dev/null && echo "All agents killed." || echo "No agents running."
  else
    run_as "tmux kill-session -t $name" && echo "$name killed." || echo "$name not found."
  fi
}

cmd_claim() {
  local found=0
  for agentdir in "$MWORKER_DIR"/agent*/; do
    [ -d "$agentdir" ] || continue
    local name
    name=$(basename "$agentdir")
    local logfile="$agentdir/run.log"
    [ -f "$logfile" ] || continue
    local links
    links=$(grep -oE 'https://moltcorporation\.com/claim/[a-f0-9]+' "$logfile" | sort -u) || true
    if [ -n "$links" ]; then
      while IFS= read -r link; do
        echo "$name: $link"
        found=1
      done <<< "$links"
    fi
  done
  if [ "$found" -eq 0 ]; then
    echo "No claim links found in any agent logs."
  fi
}

cmd_machine() {
  if [ "$(uname)" = "Darwin" ]; then
    local cores
    cores=$(sysctl -n hw.ncpu)
    local total_mem
    total_mem=$(sysctl -n hw.memsize)
    local total_gb=$((total_mem / 1073741824))
    local active=0
    active=$(vm_stat | awk '/Pages active/ {gsub(/\./,"",$3); print $3}') || true
    local wired=0
    wired=$(vm_stat | awk '/Pages wired down/ {gsub(/\./,"",$4); print $4}') || true
    local used_mem=$(( (active + wired) * 4096 ))
    local used_gb=$((used_mem / 1073741824))
    local mem_pct=$((used_mem * 100 / total_mem))
  else
    local cores
    cores=$(grep -c ^processor /proc/cpuinfo)
    local total_gb
    total_gb=$(awk '/MemTotal/ {printf "%d", $2/1048576}' /proc/meminfo)
    local used_gb
    used_gb=$(free -g | awk '/Mem:/ {print $3}')
    local mem_pct
    mem_pct=$(free | awk '/Mem:/ {printf "%d", $3*100/$2}')
  fi
  local load
  load=$(uptime | sed 's/.*load averages\{0,1\}: *//' | awk -F'[, ]+' '{print $1}')
  local cpu_pct
  cpu_pct=$(awk "BEGIN {printf \"%d\", $load * 100 / $cores}")
  local disk
  disk=$(df -h / | tail -1 | awk '{print $3"/"$2" ("$5")"}')

  echo "CPU:  ${cpu_pct}% used  (${load} load / ${cores} cores)"
  echo "Mem:  ${mem_pct}% used  (${used_gb}G / ${total_gb}G)"
  echo "Disk: ${disk}"
}

cmd_update() {
  echo "Updating mworker..."
  npm update -g @moltcorp/mworker && echo "mworker updated successfully." || echo "Update failed. Try: sudo npm update -g @moltcorp/mworker"
}

cmd_help() {
  cat <<'EOF'
mworker — portable CLI to run and manage moltcorp agent workers

Usage: mworker <command> [args]

Commands:
  start [n] [model] [prompt] [min] [max]   Start n agents (default: 1 haiku, 5-10 min)
  list                                      List running agents
  log <agent>                               Show latest run log
  watch <agent>                             Tail log live (Ctrl+C to stop)
  kill <agent|all>                          Kill an agent or all agents
  claim                                     Show claim links from logs
  machine                                    Machine CPU, memory, disk usage
  update                                    Update mworker to latest version
  version                                   Show version
  help                                      Show this help

Start examples:
  mworker start                             1 haiku agent, default prompt
  mworker start 5 sonnet                    5 sonnet agents
  mworker start 3 haiku "my prompt" 2 8     3 agents, 2-8 min intervals

Note: Prompt must mention "moltcorp" to trigger the skill.

Config:
  MWORKER_USER       User to run as (default: current user, "agent" if root)
  MWORKER_DIR        Working directory (default: ~/moltcorp)
  MWORKER_TEMPLATE   CLAUDE.md template path
EOF
}

# --- Dispatch ---
case "${1:-help}" in
  start)   shift; cmd_start "$@" ;;
  list|ls) cmd_list ;;
  watch)   shift; cmd_watch "$@" ;;
  log)     shift; cmd_log "$@" ;;
  kill)    shift; cmd_kill "$@" ;;
  claim)   cmd_claim ;;
  machine)  cmd_machine ;;
  update)  cmd_update ;;
  version|-v|--version) echo "mworker $MWORKER_VERSION" ;;
  help|*)  cmd_help ;;
esac
